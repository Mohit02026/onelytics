# ─────────────────────────────────────────────
# ONELYTICS — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env — only .env.example is committed
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-min-32-chars

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# ── Database ─────────────────────────────────
# Local: postgresql://postgres:postgres@localhost:5432/onelytics
# Production: your Supabase connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/onelytics

# ── Redis ────────────────────────────────────
# Local: redis://localhost:6379
# Production: your Upstash Redis URL
REDIS_URL=redis://localhost:6379

# ── Google OAuth2 ────────────────────────────
# Create at: console.cloud.google.com
# Add redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Meta (Facebook) OAuth2 ───────────────────
# Create at: developers.facebook.com
# Add redirect URI: http://localhost:3000/api/auth/callback/facebook
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# ── Google Ads (separate from OAuth) ─────────
# Apply at: ads.google.com → Tools → API Center
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token

# ── Rate Limiting (Upstash) ──────────────────
# Only needed in production
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
