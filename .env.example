# ─────────────────────────────────────────────────────
# ONELYTICS — Environment Variables Template
# Copy to .env and fill in your values
# NEVER commit .env — only .env.example is committed
# ─────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=
ENCRYPTION_KEY=

# ── Database ──────────────────────────────────────────
# Local: postgresql://postgres:postgres@127.0.0.1:5432/onelytics
# Prod: Supabase connection string
# NOTE: use 127.0.0.1 not localhost on Windows (Docker IPv6 issue)
DATABASE_URL=

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Google OAuth2 ─────────────────────────────────────
# 1. Create project at console.cloud.google.com
# 2. Enable APIs: Google Analytics Data API, Google Ads API, Search Console API
# 3. Create OAuth2 credentials (Web Application)
# 4. Add Authorized redirect URI: http://localhost:3000/api/integrations/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Ads Developer Token (apply at ads.google.com → Tools → API Center)
GOOGLE_ADS_DEVELOPER_TOKEN=

# ── Meta OAuth2 ───────────────────────────────────────
# Create at: developers.facebook.com → My Apps → Add a Product → Facebook Login
# Add Valid OAuth Redirect URI: http://localhost:3000/api/integrations/meta/callback
# Required permissions: ads_read, business_management
META_APP_ID=
META_APP_SECRET=

# ── TikTok Ads OAuth (Phase 8) ───────────────────────
# Create at: business-api.tiktok.com → My Apps → Create App
# Add Redirect URI: http://localhost:3000/api/integrations/tiktok/callback
# Required scope: ad.read
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

# ── LinkedIn Ads OAuth (Phase 8) ─────────────────────
# Create at: developer.linkedin.com → Create App
# Add Redirect URI: http://localhost:3000/api/integrations/linkedin/callback
# Required scopes: r_ads_reporting, r_organization_social
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── AI Summary (Phase 6) ──────────────────────────────
# Get key at: console.anthropic.com
ANTHROPIC_API_KEY=

# ── Upstash Rate Limiting (Production only) ───────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email (Resend) - optional, falls back to console.log
RESEND_API_KEY=re_xxxx
