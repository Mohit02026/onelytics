# ─────────────────────────────────────────────────────
# ONELYTICS — Environment Variables Template
# Copy to .env and fill in your values
# NEVER commit .env — only .env.example is committed
# ─────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── Database ──────────────────────────────────────────
# Local: postgresql://postgres:postgres@localhost:5432/onelytics
# Prod: Supabase connection string
DATABASE_URL=

# ── Redis ─────────────────────────────────────────────
# Local: redis://localhost:6379
# Prod: Upstash Redis URL
REDIS_URL=

# ── Google OAuth2 ─────────────────────────────────────
# Create at: console.cloud.google.com
# Enable: GA4 API, Google Ads API, Search Console API
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apply at: ads.google.com → Tools → API Center
GOOGLE_ADS_DEVELOPER_TOKEN=

# ── WordPress (Phase 2) ───────────────────────────────
# WordPress.com OAuth or self-hosted REST API key
WORDPRESS_CLIENT_ID=
WORDPRESS_CLIENT_SECRET=

# ── Meta OAuth2 (Phase 3) ─────────────────────────────
# Create at: developers.facebook.com
# Redirect URI: http://localhost:3000/api/auth/callback/facebook
META_APP_ID=
META_APP_SECRET=

# ── Upstash Rate Limiting (Production only) ───────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
